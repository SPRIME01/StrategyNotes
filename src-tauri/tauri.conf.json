{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "StrategyNotes",
  "version": "0.1.0",
  "identifier": "app.strategynotes",
  "build": {
    "beforeDevCommand": "pnpm -C ../ui dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "pnpm -C ../ui build",
    "frontendDist": "../ui/dist"
  },
  "app": {
    "windows": [
      {
        "title": "StrategyNotes",
        "width": 1200,
        "height": 800,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png"]
  }
}
