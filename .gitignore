# StrategyNotes — .gitignore

# Agent / runtime logs (OMC subtask output, etc.)
.logs/

# OMC per-session orchestration stubs (managed by the OMC system; high churn).
# Durable project state in .agents/ IS tracked (evidence.md, open_questions.md).
.agents/current_status.md
.agents/next_steps.md

# Windows download artifacts
*:Zone.Identifier

# Rust / Cargo
target/
**/*.rs.bk
# Cargo.lock IS committed — StrategyNotes is an application, reproducible builds matter

# Node / pnpm
node_modules/
dist/
.vite/
.turbo/
*.tsbuildinfo
coverage/

# Tauri
src-tauri/target/
src-tauri/gen/

# Editor / OS
.DS_Store
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
*.swp
*~

# Local env / secrets
.env
.env.*
!.env.example

# Local runtime data (the dev vault/index/daynotes created by `strategynotes serve`)
strategynotes-data/

# Tauri build artifacts (src-tauri is a standalone crate; built separately)
src-tauri/target/
src-tauri/gen/

.tmp/
